# ── Groq (existing) ──
# Get a free key at console.groq.com
GROQ_API_KEY=gsk_...

# ── Stripe (new) ──
# Get these from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...

# Create a recurring €9.99/mo Product → Price in Stripe Dashboard, copy the price_id
# https://dashboard.stripe.com/test/products
STRIPE_PRICE_ID=price_...

# After `stripe listen --forward-to localhost:3000/api/stripe-webhook` locally,
# or after creating a webhook endpoint in the Stripe Dashboard for prod.
STRIPE_WEBHOOK_SECRET=whsec_...

# Base URL used for Stripe success_url / cancel_url
# Local:   http://localhost:3000
# Prod:    https://pdf-study-tool.vercel.app
APP_BASE_URL=http://localhost:3000

# ── Resend (contact form) ──
# Sign up at https://resend.com — free tier: 3,000 emails/month
# Dashboard → API Keys → Create API Key
RESEND_API_KEY=re_...

# Inbox that receives support messages (your email)
CONTACT_EMAIL=you@example.com

PORT=3000
